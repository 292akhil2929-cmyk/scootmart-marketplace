# ══════════════════════════════════════════════════════════
# SCOOTMART.AE — ENVIRONMENT VARIABLES
# 1. Copy this file to .env.local
# 2. Fill in all values (see setup instructions below)
# 3. Add all values to Vercel Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════════════════

# ── GOOGLE GEMINI (ScootBot AI) ────────────────────────────
# Get your key: aistudio.google.com → "Get API Key" → "Create API key in new project"
GEMINI_API_KEY=

# ── STRIPE (payments) ──────────────────────────────────────
# Get keys: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# then copy the webhook signing secret shown in the CLI
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SUPABASE (database + auth) ─────────────────────────────
# Get keys: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key (server-side ONLY — never expose to client):
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── RESEND (transactional email) ───────────────────────────
# Get key: resend.com → API Keys → Create
RESEND_API_KEY=re_...
# The "from" address (must be a verified domain in Resend):
EMAIL_FROM=noreply@scootmart.ae
# Where vendor inquiry notifications go:
VENDOR_NOTIFICATION_EMAIL=hello@scootmart.ae

# ── SITE ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://scootmart.ae

# ══════════════════════════════════════════════════════════
# SETUP CHECKLIST
# ══════════════════════════════════════════════════════════
#
# 1. GEMINI
#    → aistudio.google.com
#    → Sign in with Google
#    → "Get API Key" → "Create API key in new project"
#    → Copy → paste as GEMINI_API_KEY
#
# 2. STRIPE
#    → dashboard.stripe.com → Developers → API keys
#    → Copy "Secret key"  → STRIPE_SECRET_KEY
#    → Copy "Publishable key" → NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#    → For webhooks: install Stripe CLI, run:
#      stripe listen --forward-to localhost:3000/api/stripe/webhook
#    → Copy the "whsec_..." signing secret → STRIPE_WEBHOOK_SECRET
#    → For production: create a webhook in Stripe Dashboard pointing to
#      https://yourdomain.ae/api/stripe/webhook with event: checkout.session.completed
#
# 3. SUPABASE
#    → supabase.com → New project
#    → Settings → API → copy URL and keys
#    → SQL Editor → paste contents of supabase-schema.sql → Run
#
# 4. RESEND
#    → resend.com → Sign up
#    → API Keys → Create API Key → copy → RESEND_API_KEY
#    → Domains → Add your domain → verify DNS
#    → Set EMAIL_FROM to an address at your verified domain
#
# 5. VERCEL DEPLOYMENT
#    → vercel.com → New project → import from GitHub
#    → Add ALL env vars in Vercel Dashboard → Settings → Environment Variables
#    → Deploy
# ══════════════════════════════════════════════════════════
