# ============================================
# ScootMart.ae – Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ScootMart.ae

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- OpenAI (for AI chatbot) ----
OPENAI_API_KEY=sk-...

# ---- Stripe ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Connect (for seller payouts)
STRIPE_CONNECT_CLIENT_ID=ca_...

# ---- Tabby (BNPL) ----
TABBY_API_KEY=your-tabby-api-key
TABBY_MERCHANT_CODE=your-merchant-code
NEXT_PUBLIC_TABBY_PUBLIC_KEY=your-tabby-public-key

# ---- Tamara (BNPL) ----
TAMARA_API_KEY=your-tamara-api-key
TAMARA_MERCHANT_ID=your-tamara-merchant-id
NEXT_PUBLIC_TAMARA_API_URL=https://api.tamara.co

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@scootmart.ae

# ---- Aramex / Fetchr (Delivery) ----
ARAMEX_API_KEY=your-aramex-key
ARAMEX_ACCOUNT_NUMBER=your-account
FETCHR_API_KEY=your-fetchr-key

# ---- Commission Config ----
# Default commission: 10% (configurable via admin panel)
DEFAULT_COMMISSION_PERCENT=10
MIN_COMMISSION_PERCENT=8
MAX_COMMISSION_PERCENT=12

# ---- Escrow ----
ESCROW_HOLD_DAYS=7
WARRANTY_DEFAULT_MONTHS=3
